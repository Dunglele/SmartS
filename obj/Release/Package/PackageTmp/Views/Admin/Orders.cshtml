@model Smarts_DoAn_Backup_27_11_2025.Models.CheckoutList
@{
    ViewBag.Title = "Quản lý Đơn hàng";
    Layout = "~/Views/Shared/_AdminPanel.cshtml";
}

<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
<link href="~/Content/order.css" rel="stylesheet" />

<div class="main-content container-fluid px-4">
    <header class="admin-header py-4 d-flex justify-content-between align-items-end border-bottom mb-4">
        <div>
            <h4 class="mb-1 fw-bold text-dark">Danh sách Đơn hàng</h4>
            <p class="text-muted small mb-0">Quản lý và cập nhật trạng thái đơn hàng</p>
        </div>
        <div>
            <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" onclick="location.reload()">
                <i class="bi bi-arrow-clockwise me-1"></i> Làm mới
            </button>
        </div>
    </header>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill text-success me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 border-start border-danger border-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow rounded-4 overflow-hidden mb-5">
        <div class="card-header bg-white py-3 border-bottom border-light">
            <div class="d-flex align-items-center">
                <i class="bi bi-list-ul text-primary me-2"></i>
                <h6 class="mb-0 fw-bold text-uppercase small text-muted">Danh sách chi tiết</h6>
            </div>
        </div>
        <div class="table-responsive p-3">
            <table class="table table-hover align-middle mb-0" id="orderTable" style="min-width: 900px; width:100%">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Mã ĐH</th>
                        <th>Khách hàng</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.DatHangs != null && Model.DatHangs.Any())
                    {
                        foreach (var dh in Model.DatHangs)
                        {
                            // 1. Lấy hóa đơn và xử lý an toàn dữ liệu (Trim bỏ khoảng trắng thừa)
                            var hd = Model.HoaDons.FirstOrDefault(h => h.MADH == dh.MADH);

                            // Mặc định là "Chờ xử lý" nếu không tìm thấy hóa đơn
                            string trangThaiRaw = (hd != null && !string.IsNullOrEmpty(hd.TINHTRANG)) ? hd.TINHTRANG.Trim() : "Chờ xử lý";

                            decimal tongTien = 0;
                            string jsonProducts = "[]";

                            if (hd != null)
                            {
                                tongTien = Model.ChiTietHoaDons.Where(ct => ct.MAHD == hd.MAHD).Sum(ct => ct.THANHTIEN ?? 0);
                                var listSanPham = Model.ChiTietHoaDons.Where(ct => ct.MAHD == hd.MAHD)
                                    .Select(ct => new { name = ct.TENSP, quantity = ct.SOLUONG, price = ct.GIA }).ToList();
                                jsonProducts = Newtonsoft.Json.JsonConvert.SerializeObject(listSanPham);
                            }
                            decimal VAT = tongTien * 10 / 100;

                            // 2. Logic so sánh Badge (Dùng Contains để linh hoạt hơn)
                            string badgeClass = "badge-soft-secondary"; // Mặc định màu xám
                            string iconStatus = "bi-hourglass";

                            // Chuyển về chữ thường để so sánh cho chính xác
                            string ttLower = trangThaiRaw.ToLower();

                            if (ttLower.Contains("chờ") || ttLower.Contains("chưa"))
                            {
                                badgeClass = "badge-soft-warning"; // Màu cam
                                iconStatus = "bi-hourglass-split";
                            }
                            else if (ttLower.Contains("đang giao") || ttLower.Contains("vận chuyển") || ttLower.Contains("xác nhận"))
                            {
                                badgeClass = "badge-soft-info"; // Màu xanh dương
                                iconStatus = "bi-truck";
                            }
                            else if (ttLower.Contains("đã giao") || ttLower.Contains("hoàn thành") || ttLower.Contains("thành công"))
                            {
                                badgeClass = "badge-soft-success"; // Màu xanh lá
                                iconStatus = "bi-check-circle-fill";
                            }
                            else if (ttLower.Contains("hủy") || ttLower.Contains("đóng"))
                            {
                                badgeClass = "badge-soft-danger"; // Màu đỏ
                                iconStatus = "bi-x-circle-fill";
                            }

                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-light text-dark border fw-bold text-secondary font-monospace">#@dh.MADH</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initial rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm">
                                            @(!string.IsNullOrEmpty(dh.TEN) ? dh.TEN.Substring(0, 1).ToUpper() : "?")
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@dh.HO @dh.TEN</div>
                                            <div class="small text-muted"><i class="bi bi-telephone me-1"></i>@dh.SODIENTHOAI</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="fw-bold text-dark">
                                    @string.Format("{0:N0} đ", tongTien + VAT)
                                </td>
                                <td>
                                    <span class="badge rounded-pill fw-normal px-3 py-2 text-nowrap @badgeClass">
                                        <i class="bi @iconStatus me-1"></i> @trangThaiRaw
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-pill" role="group">
                                        <button type="button" class="btn btn-sm btn-white text-primary border-end"
                                                data-products='@jsonProducts'
                                                onclick="showOrderDetail('@dh.MADH', '@dh.HO @dh.TEN', '@dh.DIACHI', '@dh.PHUONGTHUCTHANHTOAN', this)"
                                                data-bs-toggle="tooltip" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-white text-dark fw-bold px-3"
                                                onclick="openOrderModal('@dh.MADH', '@dh.EMAIL', '@trangThaiRaw')"
                                                data-bs-toggle="tooltip" title="Cập nhật trạng thái">
                                            <span>Cập nhật</span> <i class="bi bi-pencil-square ms-1"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="orderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-light border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark">📝 Cập nhật đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("UpdateOrder", "Admin", FormMethod.Post))
            {
                <div class="modal-body p-4 pt-3">
                    <div class="bg-light p-3 rounded-3 mb-3 border border-dashed">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="small fw-bold text-secondary">MÃ ĐƠN:</span>
                            <input type="text" class="form-control-plaintext form-control-sm text-end fw-bold text-primary py-0 w-auto" name="MADH" id="modalMADH" readonly>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="small fw-bold text-secondary">EMAIL KH:</span>
                            <input type="text" class="form-control-plaintext form-control-sm text-end fw-bold text-dark py-0 w-auto" id="modalEMAIL" readonly>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold text-dark">Trạng thái mới</label>
                        <select class="form-select form-select-lg shadow-none border-secondary bg-white" name="TINHTRANG" id="modalTRANGTHAI">
                            <option value="Chờ xử lý">⏳ Chờ xử lý</option>
                            <option value="Đang xác nhận">🔄 Đang xác nhận</option>
                            <option value="Đang giao">🚚 Đang giao hàng</option>
                            <option value="Đã giao">✅ Đã giao thành công</option>
                            <option value="Đã hủy">❌ Đã hủy đơn</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-medium" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">Lưu thay đổi</button>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header modal-receipt-header border-bottom-0">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 p-2 rounded-circle me-3"><i class="bi bi-receipt-cutoff fs-4 text-white"></i></div>
                    <div>
                        <h5 class="modal-title fw-bold text-white mb-0">Chi tiết hóa đơn</h5>
                        <p class="mb-0 text-white-50 small">Thông tin sản phẩm và thanh toán</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="p-4 bg-light border-bottom">
                    <div class="row g-3">
                        <div class="col-md-7">
                            <div class="info-group">
                                <label class="text-secondary fw-bold small"><i class="bi bi-geo-alt-fill me-1 text-danger"></i> Địa chỉ giao hàng</label>
                                <div class="bg-white p-2 rounded border text-break" id="divAddress"></div>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="info-group">
                                <label class="text-secondary fw-bold small"><i class="bi bi-credit-card-2-front-fill me-1 text-primary"></i> Thanh toán</label>
                                <div class="bg-white p-2 rounded border" id="divPayment"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="p-4">
                    <h6 class="text-uppercase text-secondary fw-bold x-small mb-3 ps-2">Danh sách sản phẩm</h6>
                    <div class="table-responsive rounded-3 border">
                        <table class="table align-middle mb-0 table-borderless table-striped">
                            <thead class="bg-primary bg-opacity-10 text-primary">
                                <tr>
                                    <th class="ps-4 py-3" style="width: 55%">Sản phẩm</th>
                                    <th class="text-center py-3">Số lượng</th>
                                    <th class="text-end pe-4 py-3">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody id="modalProductList"></tbody>
                            <tfoot class="border-top bg-white">
                                <tr>
                                    <td colspan="2" class="text-end fw-bold py-4 text-secondary">TỔNG CỘNG:</td>
                                    <td class="text-end pe-4 py-4 fw-bold text-primary fs-4" id="modalTotal">0 đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 pb-4 px-4 justify-content-between">
                <span class="text-muted small fst-italic">* Giá đã bao gồm thuế VAT</span>
                <div>
                    <button type="button" class="btn btn-light rounded-pill me-2" data-bs-dismiss="modal">Đóng</button>
                    <button type="button" class="btn btn-primary rounded-pill shadow-sm" id="btnPrintInvoice" onclick="printAdminOrder()">
                        <i class="bi bi-printer me-2"></i>In hóa đơn
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<script>
    $(document).ready(function () {
        // === 1. Kích hoạt DataTables (Tự động căn chỉnh Flexbox) ===
        $('#orderTable').DataTable({
            "dom": '<"d-flex justify-content-between align-items-center mb-3"lf>' +
                'rt' +
                '<"d-flex justify-content-between align-items-center mt-3"ip>',
            "language": {
                "lengthMenu": "Hiển thị _MENU_",
                "search": "",
                "searchPlaceholder": "Tìm kiếm đơn hàng...",
                "zeroRecords": "Không tìm thấy dữ liệu",
                "info": "Hiển thị _START_ - _END_ trong _TOTAL_ đơn",
                "infoEmpty": "Chưa có dữ liệu",
                "infoFiltered": "(lọc từ _MAX_ đơn)",
                "paginate": { "first": "«", "last": "»", "next": "›", "previous": "‹" }
            },
            "pageLength": 10,
            "ordering": false,
            "autoWidth": false,
            "responsive": true
        });

        // Kích hoạt Tooltip của Bootstrap
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });
    });

    // === 2. Hàm mở Modal Cập nhật ===
    function openOrderModal(id, email, status) {
        document.getElementById('modalMADH').value = id;
        document.getElementById('modalEMAIL').value = email;
        document.getElementById('modalTRANGTHAI').value = status;
        new bootstrap.Modal(document.getElementById('orderModal')).show();
    }

    // === 3. Hàm hiển thị Chi tiết & Chuẩn bị in ===
    function showOrderDetail(orderId, customerName, address, payment, btn) {
        document.getElementById('divAddress').innerText = address || "Chưa cập nhật";
        document.getElementById('divPayment').innerText = payment || "Tiền mặt";

        // Lưu thông tin vào nút In để dùng sau
        const printBtn = document.getElementById('btnPrintInvoice');
        printBtn.setAttribute('data-id', orderId);
        printBtn.setAttribute('data-name', customerName);

        // Parse dữ liệu sản phẩm
        const jsonString = btn.getAttribute('data-products');
        let products = [];
        try { products = JSON.parse(jsonString); } catch (e) { console.error("Lỗi JSON", e); }

        const tbody = document.getElementById('modalProductList');
        const totalElement = document.getElementById('modalTotal');
        tbody.innerHTML = '';
        let totalAmount = 0;

        if (products && products.length > 0) {
            products.forEach(p => {
                const lineTotal = p.price * p.quantity;
                const VAT = lineTotal * 0.1; // VAT 10%
                totalAmount += lineTotal + VAT;
                const formattedPrice = lineTotal.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' });

                const row = `
                <tr>
                    <td class="ps-4 fw-bold text-dark">${p.name}</td>
                    <td class="text-center"><span class="badge bg-white text-dark border rounded-pill">x${p.quantity}</span></td>
                    <td class="text-end pe-4 fw-medium text-dark">${formattedPrice}</td>
                </tr>`;
                tbody.innerHTML += row;
            });
        } else {
            tbody.innerHTML = `<tr><td colspan="3" class="text-center text-muted py-3"><i>Không có thông tin chi tiết</i></td></tr>`;
        }

        totalElement.innerText = totalAmount.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' });
        new bootstrap.Modal(document.getElementById('detailModal')).show();
    }

    // === 4. Hàm In Hóa Đơn ===
    function printAdminOrder() {
        const btn = document.getElementById('btnPrintInvoice');
        const orderId = btn.getAttribute('data-id');
        const customerName = btn.getAttribute('data-name');
        const modalContent = document.querySelector('#detailModal .modal-body').innerHTML;

        const printWindow = window.open('', '', 'height=800,width=800');

        printWindow.document.write(`
            <html>
            <head>
                <title>In Hóa Đơn #${orderId}</title>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
                <style>
                    body { font-family: 'Segoe UI', sans-serif; padding: 40px; color: #000; }
                    .table { margin-top: 20px; width: 100%; border-collapse: collapse; }
                    .table th, .table td { border: 1px solid #ddd; padding: 8px; }
                    .text-end { text-align: right; } .text-center { text-align: center; }
                    .fw-bold { font-weight: bold; }
                    .signature-section { margin-top: 50px; display: flex; justify-content: space-between; }
                    .signature-box { text-align: center; width: 40%; }
                </style>
            </head>
            <body>
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-uppercase">HÓA ĐƠN BÁN HÀNG</h2>
                    <p class="mb-1">Mã đơn: <strong>#${orderId}</strong></p>
                    <p class="mb-0">Khách hàng: <strong>${customerName}</strong></p>
                    <small class="text-muted">Ngày in: ${new Date().toLocaleString('vi-VN')}</small>
                </div>
                <hr>
                ${modalContent}
                <div class="signature-section">
                    <div class="signature-box"><p class="fw-bold">Người lập phiếu</p><br><br><br><p>(Ký, họ tên)</p></div>
                    <div class="signature-box"><p class="fw-bold">Khách hàng</p><br><br><br><p>(Ký, họ tên)</p></div>
                </div>
            </body>
            </html>
        `);

        printWindow.document.close();
        setTimeout(() => {
            printWindow.focus();
            printWindow.print();
            printWindow.close();
        }, 500);
    }
</script>