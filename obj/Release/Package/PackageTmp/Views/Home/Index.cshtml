@model IEnumerable<Smarts_DoAn_Backup_27_11_2025.Models.SANPHAM>
@{
    ViewBag.Title = "Trang Chủ";
    int n = 0;
    decimal tamtinh = 0;
}

<main>
    <section class="container py-5 mt-4 mb-5">
        <div class="row align-items-center">
            <div class="col-md-6 order-2 order-md-1 text-center text-md-start">
                <h1 class="display-4 fw-bold mb-3">Khám Phá Chiếc Smartphones Tiếp Theo Của Bạn</h1>
                <p class="fs-5 text-muted mb-4">Phát hành bản mới nhất, vừa ra mắt thoải mái nhất</p>
                <div class="d-flex justify-content-center justify-content-md-start gap-2">
                    <a href="@Url.Action("Contact", "Home")" class="btn btn-outline-dark btn-lg rounded-pill px-4">Đặt hàng ngay</a>
                    <a href="@Url.Action("ProductList", "Products")" class="btn btn-outline-dark btn-lg rounded-pill px-4">Mua ngay</a>
                </div>
            </div>

            <div class="col-md-6 order-1 order-md-2 mb-4 mb-md-0">
                <img src="@Url.Content("~/img_product/gif/gif_test.gif")" class="img-fluid rounded-4 shadow-lg" alt="Hero Image">
            </div>
        </div>
    </section>

    <section class="container mb-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Smartphones nổi bật 2025 !!!</h2>
            <p class="text-muted">Cùng kiểm tra sản phẩm "hot" nào!</p>
            <a href="@Url.Action("ProductList", "Products")" class="btn btn-dark btn-sm rounded-pill px-4">Xem tất cả</a>
        </div>

        <div class="row g-3 g-md-4">
            @foreach (var item in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card product-card h-100 border-0 shadow-sm overflow-hidden">

                        <a href="@Url.Action("Details", "Products")/@item.MASP" class="d-block text-decoration-none">
                            <div class="product-image-frame">
                                <img src="@item.ANHSP" alt="@item.TENSP">
                            </div>
                        </a>
                        <div class="card-body text-center d-flex flex-column p-3">
                            <a href="@Url.Action("Details", "Products")/@item.MASP" class="text-decoration-none text-dark">
                                <h5 class="card-title fs-6 fw-bold text-truncate" title="@item.TENSP">@item.TENSP</h5>
                            </a>

                            <p class="card-text fw-bold text-primary my-2">@string.Format("{0:N0}", item.GIA) VNĐ</p>
                            @using (Html.BeginForm("Cart", "Payment"))
                            {

                                @*@tamtinh = item.GIA * ;*@
                                <input type="hidden" name="MASP" value="@item.MASP" />
                                <input type="hidden" name="MAND" value="@Session["MAND"]" />
                                <input type="hidden" name="ANHSP" value="@item.ANHSP" />
                                <input type="hidden" name="TENSP" value="@item.TENSP" />
                                <input type="hidden" name="GIA" value="@item.GIA" />
                                <input type="hidden" name="SOLUONG" value="1" />
                                <input type="hidden" name="TAMTINH" value="@item.GIA" />


                                <button type="submit" class="btn btn-dark btn-sm mt-auto w-100 rounded-pill py-2">
                                    <i class="bi bi-cart-plus me-1"></i>
                                    <span class="d-none d-md-inline">Thêm vào giỏ</span>
                                    <span class="d-inline d-md-none">Mua</span>
                                </button>
                            }
                        </div>
                    </div>
                </div>
                n++;
                if (n == 8)
                {
                    break;
                }
            }
        </div>
    </section>

    <section class="container mb-5">
        <div class="card border-0 promo-banner bg-dark text-white overflow-hidden rounded-4">
            <div class="row g-0 align-items-center">
                <div class="col-md-7">
                    <img src="@Url.Content("~/img_product/thumb/hero__mdl3lpkglcia_large_2x.jpg")" class="img-fluid w-100 h-100 promo-banner-img" style="min-height: 300px; object-fit: cover;" alt="Promotion">
                </div>
                <div class="col-md-5 p-4 p-lg-5 text-center text-md-start">
