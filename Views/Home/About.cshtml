@{
    ViewBag.Title = "Về chúng tôi";
}

<main class="container my-5" >

    <div class="text-center py-5" style="margin-top: -30px;">
        <span class="badge bg-primary-subtle text-primary mb-2 px-3 py-2 rounded-pill">Đồ án môn học</span>
        <h1 class="display-5 fw-bold mb-3">Câu Chuyện Về SmartS</h1>
        <p class="fs-5 text-muted">Đồ án Công Nghệ Thông Tin - HUIT</p>
        <div class="mx-auto mt-4" style="width: 60px; height: 4px; background: var(--primary-color, #151717); border-radius: 2px;"></div>
    </div>

    <section class="mb-5 py-4">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <div class="position-relative">
                    <img src="@Url.Content("~/img_product/thumb/huit_thumb_1.jpg")"
                         class="img-fluid rounded-4 shadow-lg w-100"
                         alt="HUIT Campus"
                         style="object-fit: cover; min-height: 350px;">
                    <div class="position-absolute bottom-0 end-0 bg-white p-3 rounded-top-4 shadow-sm d-none d-lg-block" style="margin-right: 2rem;">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-code-slash fs-3 text-primary"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Tech Stack</h6>
                                <small class="text-muted">ASP.NET MVC & SQL</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <h2 class="fw-bold mb-3">Giải pháp quản lý hiện đại</h2>
                <p class="lead text-muted mb-4">
                    SmartS được xây dựng với mục tiêu mang đến một giải pháp toàn diện cho việc kinh doanh điện thoại di động.
                </p>
                <p class="text-muted">
                    Hệ thống giúp tự động hóa quy trình quản lý sản phẩm, khách hàng, đơn hàng và nhân viên. Chúng tôi tập trung vào trải nghiệm người dùng, giúp việc tra cứu, so sánh và mua sắm smartphone trở nên nhanh chóng và thú vị hơn bao giờ hết.
                </p>
                <div class="row g-3 mt-2">
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span class="fw-bold small">Quản lý kho hàng</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span class="fw-bold small">Thống kê doanh thu</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span class="fw-bold small">Mua sắm trực tuyến</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span class="fw-bold small">Bảo mật thông tin</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-5 py-4 bg-light rounded-4 px-4 px-md-5">
        <div class="row align-items-center g-5">
            <div class="col-md-6 order-2 order-md-1">
                <h2 class="fw-bold mb-4">Trải nghiệm người dùng tối ưu</h2>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-white p-3 rounded-circle shadow-sm text-primary">
                            <i class="bi bi-person-heart fs-4"></i>
                        </div>
                    </div>
                    <div class="ms-3">
                        <h5 class="fw-bold">Dành cho Khách hàng</h5>
                        <p class="text-muted small">Giao diện thân thiện, hiển thị rõ ràng các sản phẩm theo thương hiệu, danh mục và mức giá. Tìm kiếm chiếc điện thoại mơ ước chỉ trong vài cú click.</p>
                    </div>
                </div>

                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <div class="bg-white p-3 rounded-circle shadow-sm text-danger">
                            <i class="bi bi-gear-wide-connected fs-4"></i>
                        </div>
                    </div>
                    <div class="ms-3">
                        <h5 class="fw-bold">Dành cho Quản trị viên</h5>
                        <p class="text-muted small">Hệ thống Dashboard trực quan cho phép thêm, sửa, xóa sản phẩm, theo dõi tồn kho và xử lý đơn hàng chuyên nghiệp.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 order-1 order-md-2 text-center">
                <img src="@Url.Content("~/img_product/thumb/s_t_thumb.jpg")"
                     class="img-fluid rounded-4 shadow-lg w-100"
                     alt="SmartShow Feature"
                     style="object-fit: cover; min-height: 350px;">
            </div>
        </div>
    </section>

    <section class="text-center py-5 mx-auto" style="max-width: 800px;">
        <i class="bi bi-mortarboard-fill fs-1 text-muted mb-3 d-block"></i>
        <h3 class="fw-bold mb-3">Tinh thần học hỏi & Sáng tạo</h3>
        <p class="text-muted fs-5 mb-4">
            "Đồ án được phát triển nhằm minh họa cách thức một hệ thống quản lý bán hàng có thể hỗ trợ doanh nghiệp nâng cao hiệu suất và trải nghiệm người dùng."
        </p>
        <a href="@Url.Action("Index", "Home")" class="btn btn-dark btn-lg rounded-pill px-5">
            Khám phá cửa hàng <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </section>

    <section class="newsletter-box mt-5">
        <p>Đăng ký ngay để nhận tin tức mới từ cửa hàng !!!</p>
    </section>

</main>